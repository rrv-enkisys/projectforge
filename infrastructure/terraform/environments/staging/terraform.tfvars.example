project_id  = "projectforge-4314f"
region      = "us-central1"
environment = "staging"
domain_name = "staging.projectforge.app"

firebase_project_id = "projectforge-4314f"
db_tier             = "db-g1-small"

api_gateway_cpu    = "1"
api_gateway_memory = "512Mi"
api_gateway_min    = 1
api_gateway_max    = 5

core_service_cpu    = "1"
core_service_memory = "1Gi"
