core_service_max    = 5

ai_service_cpu    = "2"
ai_service_memory = "2Gi"
ai_service_min    = 1
ai_service_max    = 3

notification_cpu    = "0.5"
notification_memory = "256Mi"
notification_min    = 1
notification_max    = 3

