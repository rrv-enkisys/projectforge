# GCP Configuration
GCP_PROJECT_ID=projectforge-dev
GCP_REGION=us-central1
VERTEX_AI_PROJECT=projectforge-dev
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Firebase
FIREBASE_PROJECT_ID=projectforge-dev
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=projectforge-dev.firebaseapp.com
FIREBASE_STORAGE_BUCKET=projectforge-dev.appspot.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projectforge

# Redis
REDIS_URL=redis://localhost:6379

# External Services
RESEND_API_KEY=re_your_api_key
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password

# Service URLs (for local development)
API_GATEWAY_URL=http://localhost:8080
CORE_SERVICE_URL=http://localhost:8081
AI_SERVICE_URL=http://localhost:8082
NOTIFICATION_SERVICE_URL=http://localhost:8083

# Environment
NODE_ENV=development
