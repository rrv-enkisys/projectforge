# Server Configuration
HOST=0.0.0.0
PORT=8001
ENVIRONMENT=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/projectforge

# Vertex AI Configuration
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
VERTEX_EMBEDDING_MODEL=textembedding-gecko@004
VERTEX_LLM_MODEL=gemini-1.5-pro
EMBEDDING_DIMENSIONS=768

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNKS_PER_QUERY=5

# Cloud Storage
GCS_BUCKET_NAME=projectforge-documents

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Google Cloud Credentials (optional if using Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
